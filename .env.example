# supabase configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# r2 (cloudflare) s3-compatible storage
CF_R2_ACCESS_KEY_ID=your_r2_access_key_id
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_R2_BUCKET=babalola-uploads
CF_R2_PUBLIC_URL=https://cdn.babalola.dev

# jwt session encryption secret
JWT_SECRET=your_secure_random_secret_here

# admin credentials (for simple admin auth)
ADMIN_EMAIL=admin@kokokollective.com
ADMIN_PASSWORD=your_secure_password
